{
  "name": "robin-sidekick",
  "productName": "Robin",
  "version": "0.4.0",
  "description": "A mac-first menu bar sidekick for web-grounded chat and local AI.",
  "main": ".webpack/main",
  "scripts": {
    "setup": "bash ./scripts/check-prereqs.sh",
    "dev": "bash ./scripts/dev.sh",
    "dev:raw": "electron-forge start",
    "start": "npm run dev",
    "lint": "eslint src test --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --import tsx --test \"test/**/*.test.ts\"",
    "format": "prettier --write \"{src,test}/**/*.{ts,tsx}\" \"*.{js,json,md,mjs}\"",
    "format:check": "prettier --check \"{src,test}/**/*.{ts,tsx}\" \"*.{js,json,md,mjs}\"",
    "check": "npm run lint && npm run typecheck && npm run test:unit && npm run format:check",
    "test": "npm run check",
    "clean": "bash ./scripts/clean-artifacts.sh",
    "clean:app": "bash ./scripts/clean-dev.sh",
    "clean:all": "npm run clean && npm run clean:app",
    "package": "electron-forge package",
    "package:mac": "electron-forge package --platform=darwin",
    "make": "electron-forge make",
    "make:mac": "electron-forge make --platform=darwin",
    "release:prepare": "bash ./scripts/create-release.sh",
    "release:publish": "bash ./scripts/deploy-release.sh",
    "release": "bash ./scripts/release.sh",
    "install:mac": "bash ./scripts/install-mac-app.sh",
    "uninstall:mac": "bash ./scripts/uninstall-mac-app.sh",
    "open:user-data": "bash ./scripts/open-user-data.sh"
  },
  "keywords": [
    "electron",
    "menubar",
    "assistant",
    "ollama",
    "perplexity"
  ],
  "author": "Karan Singh",
  "license": "MIT",
  "dependencies": {
    "@fontsource/capriola": "^5.2.7",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/gochi-hand": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "openai": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.10.2",
    "@electron-forge/maker-deb": "7.10.2",
    "@electron-forge/maker-dmg": "7.10.2",
    "@electron-forge/maker-rpm": "7.10.2",
    "@electron-forge/maker-squirrel": "7.10.2",
    "@electron-forge/maker-zip": "7.10.2",
    "@electron-forge/plugin-webpack": "7.10.2",
    "@eslint/js": "^9.38.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vercel/webpack-asset-relocator-loader": "^1.10.0",
    "autoprefixer": "^10.4.0",
    "css-loader": "^7.0.0",
    "electron": "41.0.2",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "node-loader": "^2.1.0",
    "postcss": "^8.5.0",
    "postcss-loader": "^8.1.0",
    "prettier": "^3.6.2",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.20.6",
    "ts-loader": "^9.5.0",
    "typescript-eslint": "^8.46.2",
    "typescript": "^5.8.0"
  }
}
